APP_NAME="QEMU Web Control"
# PHP version for Docker build (Ubuntu 24.04: 8.3). Set 8.4 when available in repos.
PHP_VERSION=8.3
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use server IP or hostname reachable from clients (e.g. http://192.168.1.100:8081) for VNC WebSocket
APP_URL=http://localhost
APP_PORT=8080
APP_SSL_PORT=8443
# Timezone for logs (e.g. Europe/Moscow, Europe/London). Leave empty to use host /etc/timezone
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

COMPOSE_PROJECT_NAME=qemu

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=qemu_control
DB_USERNAME=qemu_user
DB_PASSWORD=qemu_password
DB_ROOT_PASSWORD=root_password
DB_EXTERNAL_PORT=3307

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

QEMU_BIN_PATH=/usr/bin/qemu-system-x86_64
QEMU_TARGET_ARCHES=x86_64
QEMU_APT_PACKAGES="qemu-utils"
QEMU_IMG_PATH=/usr/bin/qemu-img
QEMU_VM_STORAGE=/var/lib/qemu/vms
QEMU_ISO_STORAGE=/var/lib/qemu/iso
QEMU_ISO_VOLUME=/var/lib/qemu/iso
QEMU_ISO_DIRECTORIES=/var/lib/qemu/iso,/srv/iso
# Staging dir for ISO upload (must be same path on host and in Docker for move to work)
QEMU_ISO_UPLOAD_STAGING=/var/lib/qemu/iso-staging
# QEMU_ISO_UPLOAD_DIRECTORIES=  # paths for upload combobox; if not set, uses QEMU_ISO_DIRECTORIES

# VNC via QemuControlService (websockify on host, port 50055). Set by install.sh.
# VNC_WS_HOST=127.0.0.1:50055
# VNC_PROXY_VIA_QEMU_CONTROL=true
# VNC_SSL_CERT=  # path to SSL cert for wss:// (set by install.sh if docker/nginx/ssl/server.crt exists)

# QMP socket dir for preview (must be same on host and in container)
# QEMU_QMP_SOCKET_DIR=/var/qemu/qmp

# External QEMU via QemuControlService (required; QEMU runs on host only)
# QEMU_USE_EXTERNAL=true
# QEMU_CONTROL_SERVICE_URL=http://127.0.0.1:50054
# Docker bridge: run fix-boot-media-docker.sh or set http://172.17.0.1:50054 (gateway IP)
# QemuControlService logs: /var/log/QemuControlService.log (on host)

# QemuBootImagesControlService HTTP API (ISO delete). Set by install.sh automatically.
# Host network: http://127.0.0.1:50052 | Docker bridge: http://172.17.0.1:50052 | Docker Desktop: http://host.docker.internal:50052
# BOOT_MEDIA_SERVICE_URL=http://127.0.0.1:50052

# Let's Encrypt domain (for certificates:renew command, or set via Settings > Certificates)
# LETSENCRYPT_DOMAIN=qemu.example.com